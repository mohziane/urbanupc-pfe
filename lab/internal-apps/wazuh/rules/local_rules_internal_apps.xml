<!--
  Wazuh custom rules for MaFormation + MaCandidature audit events.
  IDs 100300-100299 reserved for this lab.
  Place in /var/ossec/etc/rules/ on vm-siem01 and restart wazuh-manager.
-->
<group name="internal_apps,authentication,">

  <!-- Base parent rule: any audit event from the apps -->
  <rule id="100300" level="3">
    <decoded_as>json</decoded_as>
    <field name="kind">audit</field>
    <description>internal-apps: audit event ($(event)) from $(app)</description>
    <group>audit,</group>
  </rule>

  <!-- Single login failure (low) -->
  <rule id="100301" level="5">
    <if_sid>100300</if_sid>
    <field name="event">^auth.login_failed$</field>
    <description>internal-apps: login failed for $(samAccount)$(email) from $(ip)</description>
    <group>authentication_failed,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- Brute force: 5 failures in 120s from same IP (high) -->
  <rule id="100302" level="10" frequency="5" timeframe="120">
    <if_matched_sid>100301</if_matched_sid>
    <same_source_ip />
    <description>internal-apps: brute force login attempt - 5 failures in 2min from $(srcip)</description>
    <group>authentication_failures,brute_force,</group>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- Account locked -->
  <rule id="100303" level="8">
    <if_sid>100300</if_sid>
    <field name="event">^auth.login_locked$</field>
    <description>internal-apps: account locked after repeated failed logins (sub=$(sub))</description>
    <group>authentication_failed,account_locked,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- IDOR attempt (high — someone tried to access another user's resource) -->
  <rule id="100310" level="10">
    <if_sid>100300</if_sid>
    <field name="event">^authz.idor_attempt$</field>
    <description>internal-apps: IDOR attempt by $(sub) on $(url)</description>
    <group>web_attack,authz,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <!-- Forbidden — privilege escalation attempt -->
  <rule id="100311" level="8">
    <if_sid>100300</if_sid>
    <field name="event">^authz.denied$</field>
    <description>internal-apps: privilege escalation attempt by $(sub) (role=$(role))</description>
    <group>authz,privilege_escalation,</group>
    <mitre>
      <id>T1078</id>
    </mitre>
  </rule>

  <!-- File-upload mime-type mismatch (likely malicious upload attempt) -->
  <rule id="100320" level="9">
    <if_sid>100300</if_sid>
    <field name="event">^upload.mime_mismatch$</field>
    <description>internal-apps: malicious file upload (mime mismatch) by $(sub), declared=$(declared)</description>
    <group>web_attack,malware,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <!-- Successful login (informational, but useful in correlation) -->
  <rule id="100330" level="3">
    <if_sid>100300</if_sid>
    <field name="event">^auth.login_ok$</field>
    <description>internal-apps: successful login by $(samAccount)$(email)</description>
    <group>authentication_success,</group>
  </rule>

  <!-- Email verified -->
  <rule id="100331" level="3">
    <if_sid>100300</if_sid>
    <field name="event">^auth.email_verified$</field>
    <description>internal-apps: email verified (sub=$(sub))</description>
  </rule>

  <!-- Rate-limit triggered (suspicious — automated client) -->
  <rule id="100340" level="7">
    <if_sid>100300</if_sid>
    <field name="event">^auth.rate_limited$</field>
    <description>internal-apps: rate limit triggered from $(ip)</description>
    <group>recon,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>
</group>

<!-- Container escape detection via Docker daemon events -->
<group name="container_escape,linux,">

  <!-- Parent: any Docker daemon event (JSON from docker-events-watcher.sh) -->
  <rule id="100350" level="2">
    <decoded_as>json</decoded_as>
    <field name="type">^container$</field>
    <description>docker: container event $(evt_action) on $(actor)</description>
    <group>docker,</group>
  </rule>

  <!-- Critical: container exec (escape signature when triggered by a web app) -->
  <rule id="100351" level="12">
    <if_sid>100350</if_sid>
    <field name="evt_action">^exec_</field>
    <description>HOST: docker exec on container $(actor) — POSSIBLE CONTAINER ESCAPE (T1611)</description>
    <group>container_escape,</group>
    <mitre>
      <id>T1611</id>
      <id>T1610</id>
    </mitre>
  </rule>

  <!-- Deploy a new container on the host (unusual outside of CI/CD) -->
  <rule id="100352" level="10">
    <if_sid>100350</if_sid>
    <field name="evt_action" type="pcre2">^(create|start)$</field>
    <description>HOST: docker $(evt_action) on $(actor) ($(image))</description>
    <group>docker_deploy,</group>
    <mitre>
      <id>T1610</id>
    </mitre>
  </rule>
</group>
